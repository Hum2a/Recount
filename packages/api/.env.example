# In development, missing keys get placeholders so the server can start (frontend-only work).
# Use RELAXED_ENV=0 to require a full .env locally (same as production).
# RELAXED_ENV=0

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

OPENAI_API_KEY=sk-...

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
WEB_URL=http://localhost:3000

# Optional; not required if using Supabase JWT verification only
JWT_SECRET=replace-with-32-char-min-secret

# Optional: shared secret for POST /api/jobs/weekly-digest (header X-Recount-Job-Secret)
# DIGEST_JOB_SECRET=your-long-random-secret-here
