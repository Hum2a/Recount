# In development, missing keys get placeholders so the server can start (frontend-only work).
# Use RELAXED_ENV=0 to require a full .env locally (same as production).
# RELAXED_ENV=0

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

OPENAI_API_KEY=sk-...
# Optional: OpenAI chat model for AI reports (default gpt-4o-mini). Same model used for narrative + score JSON.
# OPENAI_REPORT_MODEL=gpt-4o-mini
# Optional: max POST /api/reports/generate attempts per user per UTC day (requires migration 013). Default 15.
# REPORT_GENERATE_MAX_PER_UTC_DAY=15

STRIPE_SECRET_KEY=sk_test_...
# Lifetime one-time price from Stripe Dashboard (test vs live must match STRIPE_SECRET_KEY mode).
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

PORT=3001
NODE_ENV=development
# Comma-separated. Include every origin you use in the browser (localhost vs 127.0.0.1 differ).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WEB_URL=http://localhost:3000

# Optional, currently unused (auth uses Supabase JWTs). Safe to omit.
# JWT_SECRET=replace-with-32-char-min-secret

# Optional: shared secret for POST /api/jobs/weekly-digest (header X-Recount-Job-Secret)
# DIGEST_JOB_SECRET=your-long-random-secret-here

# Optional: SHA-256(salt|client_ip) stored on login_events for support (no raw IPs). Min 16 chars.
# LOGIN_AUDIT_SALT=your-long-random-secret-here

# Optional: behind a reverse proxy, set to 1 so rate limits and login IP use X-Forwarded-For.
# TRUST_PROXY=1
# Optional: proxy chain depth (default 1). Increase only if you have multiple trusted hops.
# TRUST_PROXY_HOPS=2

# Optional: Postgres URI for `npm run db:migrate` only.
# Supabase → Project Settings → Database → copy "URI" (or Session pooler if direct `db.<ref>.supabase.co` gives ENOTFOUND on your network).
# Direct example (replace YOUR_REF and password from the dashboard):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres?sslmode=require
# If DNS fails for db.*.supabase.co, use the Session mode / pooler URI shown in the same Database settings page instead.
