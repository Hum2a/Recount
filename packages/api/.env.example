# In development, missing keys get placeholders so the server can start (frontend-only work).
# Use RELAXED_ENV=0 to require a full .env locally (same as production).
# RELAXED_ENV=0

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

OPENAI_API_KEY=sk-...

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
WEB_URL=http://localhost:3000

# Optional, currently unused (auth uses Supabase JWTs). Safe to omit.
# JWT_SECRET=replace-with-32-char-min-secret

# Optional: shared secret for POST /api/jobs/weekly-digest (header X-Recount-Job-Secret)
# DIGEST_JOB_SECRET=your-long-random-secret-here

# Optional: SHA-256(salt|client_ip) stored on login_events for support (no raw IPs). Min 16 chars.
# LOGIN_AUDIT_SALT=your-long-random-secret-here

# Optional: behind a reverse proxy, set to 1 so rate limits and login IP use X-Forwarded-For.
# TRUST_PROXY=1
# Optional: proxy chain depth (default 1). Increase only if you have multiple trusted hops.
# TRUST_PROXY_HOPS=2
