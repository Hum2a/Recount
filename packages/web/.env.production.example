# Copy to `.env.production` before `npm run deploy:web` / `npm run deploy`.
# These values are inlined into the client at build time (NEXT_PUBLIC_*).
# Optional: use `.env.deploy` for the same keys - deploy-web-cf.mjs injects both into the build.

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_API_URL=https://your-api-worker.workers.dev
