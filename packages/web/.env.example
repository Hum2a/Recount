NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Dev: match `npm run dev:api` (default 3001). For production use `packages/web/.env.production` (see `.env.production.example`).
# `NEXT_PUBLIC_API_URL`: use a full URL, or a hostname only (e.g. `my-api.workers.dev`); the app prepends `https://` when the scheme is missing.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Shown on /privacy as the public privacy contact (optional but recommended for production).
# NEXT_PUBLIC_PRIVACY_EMAIL=privacy@yourdomain.com
